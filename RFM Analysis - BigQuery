UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202502`
UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202503`
UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202504`
UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202505`
UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202506`
UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202507`
UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202508`
UNION ALL SELECT OrderID, CustomerID, OrderDate, ProductType,OrderValue FROM `rfm-analysis-lf.sales.sales202509`
